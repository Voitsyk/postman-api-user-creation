  "item": [
    {
      "name": "Add users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response once",
              "function getJson() {",
              "    try {",
              "        return pm.response.json();",
              "    } catch (e) {",
              "        console.log(\"Response is not JSON\");",
              "        return null;",
              "    }",
              "}",
              "",
              "const json = getJson();",
              "",
              "// Status check",
              "pm.test(\"Status is 201\", () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// User object exists",
              "pm.test(\"User object is present\", () => {",
              "    pm.expect(json).to.have.property(\"user\");",
              "});",
              "",
              "// Only continue if user exists",
              "if (json.user) {",
              "",
              "    pm.test(\"User has ID\", () => {",
              "        pm.expect(json.user).to.have.property(\"_id\");",
              "    });",
              "",
              "    pm.test(\"User data is correct\", () => {",
              "        pm.expect(json.user.firstName).to.eql(pm.environment.get(\"firstName\"));",
              "        pm.expect(json.user.email).to.eql(pm.environment.get(\"email\"));",
              "    });",
              "",
              "// Token validation (safe)",
              "    pm.test(\"Token is present\", () => {",
              "    pm.expect(json).to.have.property(\"token\");",
              "    pm.expect(json.token).to.be.a(\"string\");",
              "});",
              "",
              "// Save user ID",
              "    pm.environment.set(\"user_id\", json.user._id);",
              "",
              "// Save email",
              "    pm.environment.set(\"email\", json.user.email);",
              "",
              "} else {",
              "    console.log(\"User object not found in response:\", json);",
              "}",
              "",
              "// Save token only if exists",
              "if (json.token) {",
              "    pm.environment.set(\"auth_token\", json.token);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const random = Math.floor(Math.random() * 1000);",
              "",
              "pm.environment.set(\"firstName\", \"user\" + random);",
              "pm.environment.set(\"lastName\", \"test\" + random);",
              "pm.environment.set(\"email\", `user${random}@gmail.com`);",
              "pm.environment.set(\"password\", \"password\" + random);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{auth_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"{{firstName}}\",\n    \"lastName\": \"{{lastName}}\",\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/users",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get User Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "function getJson() {",
              "    try {",
              "        return pm.response.json();",
              "    } catch (e) {",
              "        console.log(\"Response is not JSON\");",
              "        return null;",
              "    }",
              "}",
              "",
              "const json = getJson();",
              "",
              "try {",
              "    json = pm.response.json();",
              "} catch (e) {",
              "    console.log(\"Response is not JSON\");",
              "}",
              "",
              "pm.test(\"Status is 200\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"User has all required fields\", () => {",
              "    pm.expect(json).to.have.property(\"_id\");",
              "    pm.expect(json).to.have.property(\"firstName\");",
              "    pm.expect(json).to.have.property(\"lastName\");",
              "    pm.expect(json).to.have.property(\"email\");",
              "    pm.expect(json).to.have.property(\"__v\");",
              "});",
              "",
              "pm.test(\"Field types are correct\", () => {",
              "    pm.expect(json._id).to.be.a(\"string\");",
              "    pm.expect(json.firstName).to.be.a(\"string\");",
              "    pm.expect(json.lastName).to.be.a(\"string\");",
              "    pm.expect(json.email).to.be.a(\"string\");",
              "    pm.expect(json.__v).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Returned user matches logged-in user\", () => {",
              "    const expectedEmail = pm.environment.get(\"email\");",
              "    pm.expect(json.email).to.eql(expectedEmail);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
